# TaxTalk v31 — Required Environment Variables
# Copy this to .env.local for development
# In Vercel: add all these under Settings → Environment Variables
# NEVER commit actual values to git — this file is for reference only

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-SERVICE-ROLE-KEY
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY

# Also set these as VITE_ prefixed for client-side Supabase auth:
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY
# NOTE: Only the anon key goes to the client. Service role key MUST stay server-only.

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# From: Cloudflare Dashboard → R2 → API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=taxtalk-documents

# ─── Anthropic ────────────────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
# CRITICAL: This key MUST be server-only (no VITE_ prefix). Never expose to browser.
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# ─── Deployment ───────────────────────────────────────────────────────────────
# Your Vercel production URL — used for strict CORS enforcement
# Example: https://taxtalk.rbfinsol.in
ALLOWED_ORIGIN=https://YOUR-PRODUCTION-DOMAIN.vercel.app

# ─── Supabase Auth settings (configure in Supabase dashboard, not .env) ──────
# Dashboard → Authentication → Email → Confirm email: ENABLED
# Dashboard → Authentication → Password → Min length: 8
# Dashboard → Authentication → Password → Prevent leaked: ENABLED (HaveIBeenPwned)
# Dashboard → Authentication → Site URL: https://YOUR-PRODUCTION-DOMAIN.vercel.app
