# TaxTalk — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ─── Supabase (auth + database) ──────────────────────────────
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (Vercel functions) — never VITE_ prefix
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Cloudflare R2 (document storage) ────────────────────────
# Dashboard → R2 → Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=taxtalk-documents

# ─── Anthropic (AI extraction) ───────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Security ────────────────────────────────────────────────
ALLOWED_ORIGIN=https://taxtalk.in

# ─── Twilio / WATI (Phase 4 — WhatsApp notifications) ───────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
